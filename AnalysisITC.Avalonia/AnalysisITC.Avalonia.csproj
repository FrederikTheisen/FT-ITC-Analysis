<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>1.4.0</Version>
    <AssemblyVersion>1.4.0.0</AssemblyVersion>
    <FileVersion>1.4.0.0</FileVersion>
    <ApplicationIcon>..\Resources\appicon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaResource Include="..\Resources\appicon.ico" Link="Resources\appicon.ico" />
    <AvaloniaResource Include="..\Resources\HelpTextResource.txt" Link="Resources\HelpTextResource.txt" />
    <AvaloniaResource Include="..\Resources\ScienceHelpResource.txt" Link="Resources\ScienceHelpResource.txt" />
    <Content Include="..\Resources\AppIcon.icns" Link="Resources\AppIcon.icns" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\citation.json" Link="citation.json" CopyToOutputDirectory="PreserveNewest" />
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.5" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.5" />
    <PackageReference Include="SkiaSharp" Version="3.119.4" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.3">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AnalysisITC.Core\AnalysisITC.Core.csproj" />
  </ItemGroup>
</Project>
