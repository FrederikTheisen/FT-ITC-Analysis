<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:AnalysisITC.Avalonia"
        xmlns:processing="using:AnalysisITC.Avalonia.Processing"
        xmlns:analysis="using:AnalysisITC.Avalonia.Analysis"
        xmlns:finalfigure="using:AnalysisITC.Avalonia.FinalFigure"
        xmlns:results="using:AnalysisITC.Avalonia.Results"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="AnalysisITC.Avalonia.MainWindow"
        Title="FT-ITC Analysis"
        Icon="/Resources/appicon.ico"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="600">
    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource WorkspaceBackground}">
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,0,1">
            <Menu x:Name="InWindowMenu"
                  Background="{DynamicResource PanelBackground}" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Margin="12,10,12,8" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Data / Results"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" />
                        <TextBlock x:Name="ItemCountText"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource MutedText}" />
                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,7,0,0">
                            <Button x:Name="IncludeAllButton" Content="All" MinWidth="42" MinHeight="24" />
                            <Button x:Name="IncludeNoneButton" Content="None" MinWidth="52" MinHeight="24" />
                            <TextBlock x:Name="IncludedCountText"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>
                    <ListBox x:Name="ItemsList"
                             Grid.Row="1"
                             Margin="8,0,8,8"
                             Background="{DynamicResource PanelBackground}"
                             BorderThickness="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Padding" Value="4,3" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="28,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2" RowSpacing="0">
                                    <CheckBox IsVisible="{Binding CanInclude}"
                                              IsChecked="{Binding IsIncluded}"
                                              IsEnabled="{Binding CanIncludeActive}"
                                              Grid.RowSpan="4"
                                              Width="22"
                                              Height="40"
                                              MinWidth="22"
                                              MinHeight="40"
                                              Padding="0"
                                              VerticalAlignment="Top"
                                              Margin="0,0,6,0" />
                                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   FontSize="13"
                                                   LineHeight="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding KindLabel}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="10"
                                                   LineHeight="13"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding DateLine}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="10.5"
                                               LineHeight="11.5"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="2"
                                               Text="{Binding DetailLine}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="10.5"
                                               LineHeight="11.5"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="3"
                                               Text="{Binding FitLine}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="10.5"
                                               LineHeight="11.5"
                                               TextWrapping="Wrap"
                                               MaxLines="2" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="{DynamicResource SectionBorder}" />

            <Grid Grid.Column="2" Margin="12">
                <TabControl x:Name="WorkspaceTabs">
                    <TabItem Header="Overview">
                        <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource PanelBackground}">
                            <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1,1,1,0" Padding="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="OverviewTitleText"
                                               Text="No Selection"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <ToggleButton x:Name="OverviewRawButton"
                                                      Content="Raw Data"
                                                      MinWidth="74"
                                                      Padding="8,1"
                                                      IsChecked="True" />
                                        <ToggleButton x:Name="OverviewInjectionsButton"
                                                      Content="Injections"
                                                      MinWidth="78"
                                                      Padding="8,1" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource PanelBorder}"
                                    BorderThickness="1,0,1,0"
                                    Padding="12,10">
                                <ScrollViewer MaxHeight="190"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="OverviewDescriptionPanel"
                                                Spacing="2" />
                                </ScrollViewer>
                            </Border>
                            <Grid Grid.Row="2">
                                <Border x:Name="OverviewRawHost" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" Padding="0">
                                    <Grid>
                                        <local:ThermogramGraphControl x:Name="OverviewThermogram" />
                                        <TextBlock x:Name="OverviewText"
                                                   Margin="16"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   TextWrapping="Wrap"
                                                   IsVisible="False" />
                                    </Grid>
                                </Border>
                                <Border x:Name="OverviewInjectionsHost"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="1"
                                        IsVisible="False">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="OverviewInjectionTable"
                                                    Spacing="0" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Process Data">
                        <processing:ProcessingWorkspaceControl x:Name="ProcessingWorkspace" />
                    </TabItem>
                    <TabItem Header="Analyze Data">
                        <analysis:AnalysisWorkspaceControl x:Name="AnalysisWorkspace" />
                    </TabItem>
                    <TabItem Header="Final Figure">
                        <finalfigure:FinalFigureWorkspaceControl x:Name="FinalFigureWorkspace" />
                    </TabItem>
                </TabControl>
                <results:AnalysisResultWorkspaceControl x:Name="ResultWorkspace"
                                                        IsVisible="False" />
            </Grid>
            <Border x:Name="EmptyWorkspacePanel"
                    Grid.Column="2"
                    Margin="12"
                    Padding="36"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    IsVisible="False">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="440"
                            Spacing="12">
                    <TextBlock Text="Welcome to FT-ITC Analysis"
                               HorizontalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" />
                    <TextBlock Text="Open ITC data to begin processing, analysis, and figure preparation."
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedText}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <Button x:Name="WelcomeOpenButton"
                                Content="Open File…"
                                MinWidth="110" />
                        <Button x:Name="WelcomeReloadButton"
                                Content="Reload Last File"
                                MinWidth="130" />
                    </StackPanel>
                    <TextBlock x:Name="WelcomeLastFileText"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedText}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="20">
                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource SecondaryText}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <ProgressBar x:Name="StatusProgressBar"
                             Grid.Column="1"
                             Width="120"
                             Height="7"
                             Minimum="0"
                             Maximum="100"
                             Margin="16,0,0,0"
                             VerticalAlignment="Center"
                             IsVisible="False" />
                <TextBlock x:Name="StatusProgressText"
                           Grid.Column="2"
                           Width="38"
                           Margin="6,0,0,0"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           IsVisible="False" />
                <TextBlock x:Name="SecondaryStatusText"
                           Grid.Column="3"
                           Margin="16,0,0,0"
                           Foreground="{DynamicResource MutedText}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
