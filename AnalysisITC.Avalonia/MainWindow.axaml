<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:AnalysisITC.Avalonia"
        xmlns:processing="using:AnalysisITC.Avalonia.Processing"
        xmlns:analysis="using:AnalysisITC.Avalonia.Analysis"
        xmlns:finalfigure="using:AnalysisITC.Avalonia.FinalFigure"
        xmlns:results="using:AnalysisITC.Avalonia.Results"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="AnalysisITC.Avalonia.MainWindow"
        Title="FT-ITC Analysis"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="600">
    <Grid RowDefinitions="Auto,*,Auto" Background="#F5F7FA">
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D4DAE1" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Left">
                    <Button x:Name="OpenButton" Content="Open" MinWidth="72" />
                    <Button x:Name="ClearButton" Content="Clear" MinWidth="72" />
                    <Button x:Name="FitViewButton" Content="Fit View" MinWidth="84" />
                </StackPanel>
                <TextBlock x:Name="ToolbarStatusText"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#4D5A66"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="300,Auto,*">
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D4DAE1" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Margin="12,10,12,8" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Data / Results"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#202832" />
                        <TextBlock x:Name="ItemCountText"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Foreground="#5E6A75" />
                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,7,0,0">
                            <Button x:Name="IncludeAllButton" Content="All" MinWidth="42" MinHeight="24" />
                            <Button x:Name="IncludeNoneButton" Content="None" MinWidth="52" MinHeight="24" />
                            <TextBlock x:Name="IncludedCountText"
                                       VerticalAlignment="Center"
                                       Foreground="#5E6A75"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>
                    <ListBox x:Name="ItemsList"
                             Grid.Row="1"
                             Margin="8,0,8,8"
                             Background="#FFFFFF"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2" MinHeight="48" RowSpacing="1">
                                    <CheckBox IsVisible="{Binding CanInclude}"
                                              IsChecked="{Binding IsIncluded}"
                                              IsEnabled="{Binding CanIncludeActive}"
                                              VerticalAlignment="Top"
                                              Margin="0,0,6,0" />
                                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#202832"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding KindLabel}"
                                                   Foreground="#607080"
                                                   FontSize="10"
                                                   Margin="8,1,0,0" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding DateLine}"
                                               Foreground="#607080"
                                               FontSize="10.5"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="2"
                                               Text="{Binding DetailLine}"
                                               Foreground="#4D5A66"
                                               FontSize="10.5"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="3"
                                               Text="{Binding FitLine}"
                                               Foreground="#202832"
                                               FontSize="10.5"
                                               TextWrapping="Wrap"
                                               MaxLines="2" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="#E3E7EC" />

            <Grid Grid.Column="2" Margin="12">
                <TabControl x:Name="WorkspaceTabs">
                    <TabItem Header="Overview">
                        <Grid RowDefinitions="Auto,*" Background="#FFFFFF">
                            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D4DAE1" BorderThickness="1,1,1,0" Padding="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ToggleButton x:Name="OverviewRawButton" Content="Raw Data" IsChecked="True" MinWidth="86" />
                                    <ToggleButton x:Name="OverviewInjectionsButton" Content="Injections" MinWidth="86" />
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1">
                                <Border x:Name="OverviewRawHost" Background="#FFFFFF" BorderBrush="#D4DAE1" BorderThickness="1" Padding="0">
                                    <Grid>
                                        <local:ThermogramGraphControl x:Name="OverviewThermogram" />
                                        <TextBlock x:Name="OverviewText"
                                                   Margin="16"
                                                   Foreground="#202832"
                                                   TextWrapping="Wrap"
                                                   IsVisible="False" />
                                    </Grid>
                                </Border>
                                <Border x:Name="OverviewInjectionsHost"
                                        Background="#FFFFFF"
                                        BorderBrush="#D4DAE1"
                                        BorderThickness="1"
                                        IsVisible="False">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="OverviewInjectionTable"
                                                    Spacing="0" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Process Data">
                        <processing:ProcessingWorkspaceControl x:Name="ProcessingWorkspace" />
                    </TabItem>
                    <TabItem Header="Analyze Data">
                        <analysis:AnalysisWorkspaceControl x:Name="AnalysisWorkspace" />
                    </TabItem>
                    <TabItem Header="Final Figure">
                        <finalfigure:FinalFigureWorkspaceControl x:Name="FinalFigureWorkspace" />
                    </TabItem>
                </TabControl>
                <results:AnalysisResultWorkspaceControl x:Name="ResultWorkspace"
                                                        IsVisible="False" />
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D4DAE1" BorderThickness="0,1,0,0" Padding="8,5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusText"
                           Foreground="#4D5A66"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SecondaryStatusText"
                           Grid.Column="1"
                           Margin="16,0,0,0"
                           Foreground="#6B7682" />
            </Grid>
        </Border>
    </Grid>
</Window>
